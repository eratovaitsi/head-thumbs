import re\
import sys\
import argparse\
from pathlib import Path\
import xml.etree.ElementTree as ET\
import pandas as pd\
\
NS = "http://schema.primaresearch.org/PAGE/gts/pagecontent/2013-07-15"\
\
MIN_LINE_HEIGHT = 60\
\
KNOWN_CASTES = {\
    "bellale","salagama","karave","durave","wahumpura","panna","bathgama",\
    "rada","hunu","berava","oli","navandanna","kumbal",\
    "paduvansinnala","paduvanse",\
}\
\
RELATIONSHIP_MAP = {\
    "broeder":"brother","broeders":"brother","zuster":"sister",\
    "zoon":"son","zeon":"son","zoonen":"sons",\
    "dochter":"daughter","dogters":"daughters","dogters,":"daughters",\
    "vrouw":"wife","krouw":"wife","man":"husband",\
    "vader":"father","moeder":"mother",\
    "weduwe":"widow","weduwenaar":"widower",\
    "neef":"nephew/cousin","nicht":"niece/cousin",\
    "oom":"uncle","tante":"aunt","schoonzoon":"son-in-law",\
}\
\
GROUP_WORDS = {"zoonen","dogters","dogters,","zegnen","zegenen",\
               "kinderen","zegnen;","zoonen;","zegnen,"}\
\
NAMED_MARKERS = {"gent.","gent:","gent","genaamd","gen.","gen:"}\
\
DITTO_MARKS = {",,", '""', '"', "''"}\
\
IGNORE_WORDS = (\
    {"als", "do", "--", "-", "&", "zyn"}\
    | NAMED_MARKERS\
    | DITTO_MARKS\
)\
\
RANK_RE = re.compile(r'^(\d+)\.?$')\
RANK_L = re.compile(r'^[lL]$')\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# PARSE XML WITH COORDS\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def parse_xml(xml_path):\
    tree = ET.parse(xml_path)\
    root = tree.getroot()\
    page = root.find(f".//{{{NS}}}Page")\
    img = page.attrib.get("imageFilename", Path(xml_path).stem)\
\
    rows = []\
\
    for tl in root.iter(f"{{{NS}}}TextLine"):\
\
        lc = tl.find(f"{{{NS}}}Coords")\
        if lc is None:\
            continue\
\
        pts = [(int(p.split(",")[0]), int(p.split(",")[1]))\
               for p in lc.attrib["points"].split()]\
        ys = [p[1] for p in pts]\
\
        height = max(ys) - min(ys)\
        if height < MIN_LINE_HEIGHT:\
            continue\
\
        words = []\
\
        for w in tl.iter(f"{{{NS}}}Word"):\
\
            wc = w.find(f"{{{NS}}}Coords")\
            wt = w.find(f".//{{{NS}}}Unicode") or w.find(f".//{{{NS}}}PlainText")\
\
            text = (wt.text or "").strip() if wt is not None else ""\
            if wc is None or not text:\
                continue\
\
            wpts = [(int(p.split(",")[0]), int(p.split(",")[1]))\
                    for p in wc.attrib["points"].split()]\
\
            words.append({\
                "text": text,\
                "x": sum(p[0] for p in wpts) / len(wpts),\
                "y": sum(p[1] for p in wpts) / len(wpts),\
            })\
\
        if words:\
            rows.append(words)\
\
    return img, rows\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# CORE FIX: BLOCK-LEVEL MATCHING\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def split_persons_and_ages(words):\
    persons = []\
    ages = []\
\
    for w in words:\
        cleaned = re.sub(r"[^\d\-]", "", w["text"])\
\
        if cleaned.isdigit():\
            ages.append(w)\
        else:\
            persons.append(w)\
\
    return persons, ages\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# NAME CLEANING (RESTORED PROPERLY)\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def build_name(tokens):\
    skip = IGNORE_WORDS | set(RELATIONSHIP_MAP) | GROUP_WORDS | KNOWN_CASTES\
    parts = []\
\
    for t in tokens:\
        raw = t.strip()\
\
        if raw in DITTO_MARKS:\
            continue\
\
        if raw.lower().rstrip(".,;:") in skip:\
            continue\
\
        if RANK_RE.match(t) or RANK_L.match(t):\
            continue\
\
        parts.append(t)\
\
    return " ".join(parts).strip()\
\
\
def get_relationship(tokens):\
    for t in tokens:\
        r = RELATIONSHIP_MAP.get(t.lower().rstrip(".,;:"))\
        if r:\
            return r\
    return ""\
\
\
def get_caste(tokens):\
    for t in tokens:\
        if t.lower().rstrip(".,;:") in KNOWN_CASTES:\
            return t.lower().rstrip(".,;:").title()\
    return ""\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# рѓїѓґҐ PROPER MATCHING (SORT BY X POSITION)\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def match_people_to_ages(persons, ages):\
\
    persons = sorted(persons, key=lambda x: x["x"])\
    ages = sorted(ages, key=lambda x: x["x"])\
\
    pairs = {}\
\
    for i, p in enumerate(persons):\
        age = ages[i]["text"] if i < len(ages) else ""\
        pairs[(p["x"], p["y"])] = age\
\
    return pairs\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# PARSE ROWS\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def parse_rows(rows, img_file):\
\
    records = []\
\
    village = ""\
    caste = ""\
\
    for words in rows:\
\
        persons, ages = split_persons_and_ages(words)\
\
        age_map = match_people_to_ages(persons, ages)\
\
        tokens = [w["text"] for w in persons]\
\
        if not tokens:\
            continue\
\
        if tokens[0].lower() in ("torp", "dorp"):\
            village = " ".join(tokens[1:])\
            continue\
\
        caste_found = get_caste(tokens)\
        if caste_found:\
            caste = caste_found\
\
        relationship = get_relationship(tokens)\
        person_name = build_name(tokens)\
\
        if not person_name:\
            continue\
\
        age = age_map.get((persons[0]["x"], persons[0]["y"]), "")\
\
        records.append({\
            "source_file": img_file,\
            "village": village,\
            "person_name": person_name,\
            "relationship": relationship,\
            "caste": caste,\
            "age": age,\
            "absent": not bool(age),\
        })\
\
    return records\
\
\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
# RUN\
# вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
\
def run(inputs, output):\
\
    xml_files = []\
\
    for inp in inputs:\
        p = Path(inp)\
        if p.is_dir():\
            xml_files.extend(p.glob("*.xml"))\
        elif p.suffix == ".xml":\
            xml_files.append(p)\
\
    all_records = []\
\
    for f in xml_files:\
        img, rows = parse_xml(f)\
        all_records.extend(parse_rows(rows, img))\
\
    df = pd.DataFrame(all_records)\
\
    df.to_csv(output + ".csv", index=False)\
    df.to_excel(output + ".xlsx", index=False)\
\
    print(df.head(20))\
    print("\nDone.")\
\
\
