# вѓґЂвѓґЂ Token sets вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
GROUP_WORDS   = {"zoonen","dogters","dogters,","zegnen","zegenen",\
                 "kinderen","zegnen;","zoonen;","zegnen,"}\
NAMED_MARKERS = {"gent.","gent:","gent","genaamd","gen.","gen:"}\
DITTO_MARKS   = {",,", '""', '"', "''"}\
IGNORE_WORDS  = {"als","do","--","-","&","zyn"} | NAMED_MARKERS | DITTO_MARKS\
RANK_RE       = re.compile(r'^(\d+)\.?$')\
RANK_L        = re.compile(r'^[lL]$')   # OCR artefact: 'l' misread as '1'\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# STEP 1 вЂѓґ Parse XML into TextLine rows\
# Each row dict: {y_mid, line_height, x_first, words, text}\
# words is a list of {text, x_min, x_mid}\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def parse_xml(xml_path: str):\
    """\
    Parse a PAGE XML file into a sorted list of row dicts.\
    Uses TextLine bounding boxes for height and position,\
    and Word elements for individual token coordinates.\
    Returns (image_filename, list_of_row_dicts).\
    """\
    tree = ET.parse(xml_path)\
    root = tree.getroot()\
    page = root.find(f".//{{{NS}}}Page")\
    img  = page.attrib.get("imageFilename", Path(xml_path).stem)\
\
    rows = []\
    for tl in root.iter(f"{{{NS}}}TextLine"):\
        lc = tl.find(f"{{{NS}}}Coords")\
        if lc is None:\
            continue\
        pts    = [(int(p.split(",")[0]), int(p.split(",")[1]))\
                  for p in lc.attrib["points"].split()]\
        ys     = [p[1] for p in pts]\
        xs     = [p[0] for p in pts]\
        height = max(ys) - min(ys)\
        y_mid  = (min(ys) + max(ys)) // 2\
\
        if height < MIN_LINE_HEIGHT:\
            continue   # skip noise boxes\
\
        words = []\
        for w in tl.iter(f"{{{NS}}}Word"):\
            wc = w.find(f"{{{NS}}}Coords")\
            wt = w.find(f".//{{{NS}}}PlainText")\
            if wc is None or wt is None or not (wt.text or "").strip():\
                continue\
            wpts = [(int(p.split(",")[0]), int(p.split(",")[1]))\
                    for p in wc.attrib["points"].split()]\
            wxs  = [p[0] for p in wpts]\
            wys  = [p[1] for p in wpts]\
            words.append({\
                "text":  wt.text.strip(),\
                "x_min": min(wxs),\
                "x_mid": (min(wxs) + max(wxs)) // 2,\
            })\
\
        if not words:\
            continue\
\
        words.sort(key=lambda w: w["x_mid"])\
        rows.append({\
            "y_mid":       y_mid,\
            "line_height": height,\
            "x_first":     words[0]["x_min"],\
            "words":       words,\
            "text":        " ".join(w["text"] for w in words),\
        })\
\
    rows.sort(key=lambda r: r["y_mid"])\
    return img, rows\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# STEP 2 вЂѓґ Token-level helpers\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def split_age(words: list):\
    """\
    Peel off the rightmost word if it is in the right-margin age column.\
    Returns (remaining_words, age_string).\
    Age string is '' if value is '-' (listed but absent).\
    """\
    if words and words[-1]["x_min"] >= RIGHT_MARGIN_X:\
        raw = words[-1]["text"].rstrip(".")\
        if re.fullmatch(r'\d+', raw):\
            return words[:-1], raw\
        if raw == "-":\
            return words[:-1], ""\
    return words, ""\
\
\
def get_named_as(tokens: list):\
    """\
    Find gent. marker.  Returns (tokens_before, alias_string).\
    Alias is ONLY valid for THIS row вЂѓґ never carried to the next.\
    """\
    for i, t in enumerate(tokens):\
        if t.lower().rstrip(".:") in {m.rstrip(".:") for m in NAMED_MARKERS}:\
            alias = " ".join(tokens[i + 1:]).strip(" .,;:")\
            return tokens[:i], alias\
    return tokens, ""\
\
\
def get_relationship(tokens: list) -> str:\
    for t in tokens:\
        r = RELATIONSHIP_MAP.get(t.lower().rstrip(".,;:"))\
        if r:\
            return r\
    return ""\
\
\
def get_caste(tokens: list) -> str:\
    for t in tokens:\
        if t.lower().rstrip(".,;:") in KNOWN_CASTES:\
            return t.lower().rstrip(".,;:").title()\
    return ""\
\
\
def is_group_row(tokens: list) -> bool:\
    """True if row is purely a group-label intro (Zoonen; als, Dogters; als)."""\
    content = [t for t in tokens\
               if t.lower().rstrip(".,;:") not in {"als"}\
               and not RANK_RE.match(t)\
               and not RANK_L.match(t)]\
    return bool(content) and all(\
        t.lower().rstrip(".,;:") in GROUP_WORDS for t in content\
    )\
\
\
def build_name(tokens: list) -> str:\
    """\
    Assemble person name.\
    - Skips: ignore words, relationship words, group words, caste words,\
             rank/child-count numbers, ditto marks.\
    - Keeps: personal names, title words like Colomboge, Don, Dona etc.\
    - Flags illegible entries.\
    """\
    skip = (\
        IGNORE_WORDS\
        | set(RELATIONSHIP_MAP)\
        | GROUP_WORDS\
        | KNOWN_CASTES\
        | {"do"}\
    )\
    parts, illegible = [], False\
    for t in tokens:\
        if "onleesbaar" in t.lower():\
            illegible = True\
            continue\
        if t.lower().rstrip(".,;:") in skip:\
            continue\
        if RANK_RE.match(t) or RANK_L.match(t):\
            continue\
        parts.append(t)\
    name = " ".join(parts).strip(" .,;:-_")\
    if illegible:\
        return (name + " [illegible]").strip() if name else "[illegible]"\
    return name\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# STEP 3 вЂѓґ Interpret rows into person records\
#\
# Detection logic (transcript-only, no image needed):\
#\
#   VILLAGE ROW   : first word is "Torp" or "Dorp"\
#\
#   HEAD ROW      : tallest TextLine (line_height) among content rows,\
#                   after the village row.  This reflects the larger\
#                   handwriting used for household heads in the original.\
#\
#   FAMILY MEMBER : x_first вѓ©¤ head_x_first + CHILD_INDENT_DELTA\
#                   (same left margin zone as the head)\
#\
#   CHILD ROW     : x_first > head_x_first + CHILD_INDENT_DELTA\
#                   (indented further right than family members)\
#\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def parse_rows(rows: list, img_file: str) -> list:\
    records      = []\
    village      = ""\
    hh_rank      = ""\
    head_name    = ""\
    head_x       = 0      # x_first of the head row\
    caste        = ""\
    found_head   = False  # have we seen the head of this household yet?\
\
    # вѓґЂвѓґЂ Find the head row: tallest line that is not the village and not\
    #    a pure right-margin number row вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
    # We do one pre-pass to locate it, then a second pass to emit records.\
\
    # Pre-pass: find village row and head row indices\
    village_idx = None\
    head_idx    = None\
\
    for i, row in enumerate(rows):\
        tokens = [w["text"] for w in row["words"]]\
        if tokens and tokens[0].lower() in ("torp", "dorp"):\
            village_idx = i\
            continue\
        # Ignore pure right-margin rows (age numbers)\
        if row["x_first"] >= RIGHT_MARGIN_X:\
            continue\
        # Ignore group-label rows\
        if is_group_row(tokens):\
            continue\
        # The head is the tallest remaining content row after the village\
        if village_idx is not None and head_idx is None:\
            head_idx = i\
\
    # вѓґЂвѓґЂ Main pass вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
    for i, row in enumerate(rows):\
        main_words, age = split_age(row["words"])\
        absent  = not bool(age)\
        tokens  = [w["text"] for w in main_words]\
        x_first = row["x_first"]\
\
        if not tokens:\
            continue\
\
        # вѓґЂвѓґЂ Village row вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        if tokens[0].lower() in ("torp", "dorp"):\
            village     = " ".join(tokens[1:]).strip(" .,;:-")\
            found_head  = False\
            hh_rank     = ""\
            head_name   = ""\
            head_x      = 0\
            caste       = ""\
            continue\
\
        # вѓґЂвѓґЂ Skip pure right-margin rows вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        if x_first >= RIGHT_MARGIN_X:\
            continue\
\
        # вѓґЂвѓґЂ Skip group-label rows (Zoonen; als / Dogters; als) вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        if is_group_row(tokens):\
            continue\
\
        # вѓґЂвѓґЂ Ditto row: "also named" but no alias вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        is_ditto = bool(tokens) and tokens[0] in DITTO_MARKS\
        if is_ditto:\
            tokens   = [t for t in tokens if t not in DITTO_MARKS]\
            named_as = "gent."   # signals "also named", alias not stated here\
        else:\
            tokens, named_as = get_named_as(tokens)\
\
        # вѓґЂвѓґЂ Strip leading rank/child-count number вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        rank_token = ""\
        if tokens and (RANK_RE.match(tokens[0]) or RANK_L.match(tokens[0])):\
            rank_token = tokens[0].rstrip(".")\
            tokens     = tokens[1:]\
\
        relationship = get_relationship(tokens)\
\
        # вѓґЂвѓґЂ Caste: extract BEFORE building name so it is stripped out вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        found_caste = get_caste(tokens)\
        if found_caste:\
            caste  = found_caste\
            tokens = [t for t in tokens\
                      if t.lower().rstrip(".,;:") != found_caste.lower()]\
\
        person_name = build_name(tokens)\
        if not person_name:\
            continue\
\
        # вѓґЂвѓґЂ Classify row as HEAD / FAMILY / CHILD вѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂвѓґЂ\
        # HEAD  : this is the pre-identified head index\
        # CHILD : x_first is indented more than head by threshold\
        # FAMILY: everything else (same indent zone as head)\
        is_head = (i == head_idx)\
\
        if is_head:\
            hh_rank    = rank_token\
            head_name  = person_name\
            head_x     = x_first\
            found_head = True\
            hierarchy  = "head"\
        elif found_head and x_first > head_x + CHILD_INDENT_DELTA:\
            hierarchy  = "child"\
        else:\
            hierarchy  = "family"\
\
        records.append({\
            "source_file":    img_file,\
            "village":        village,\
            "household_rank": hh_rank,\
            "head_name":      head_name,\
            "caste":          caste,\
            "person_name":    person_name,\
            "hierarchy":      hierarchy,\
            "relationship":   relationship,\
            "named_as":       named_as,\
            "age":            age,\
            "absent":         absent,\
        })\
\
    return records\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# STEP 4 вЂѓґ Save combined output\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def save_outputs(df: pd.DataFrame, base_path: str):\
    out  = Path(base_path)\
    csv  = out.with_suffix(".csv")\
    xlsx = out.with_suffix(".xlsx")\
\
    df.to_csv(csv, index=False, encoding="utf-8-sig")\
    print(f"  CSV   вѓ¦ѓІ {csv}")\
\
    with pd.ExcelWriter(xlsx, engine="openpyxl") as writer:\
        df.to_excel(writer, index=False, sheet_name="Census")\
        ws = writer.sheets["Census"]\
        for col in ws.columns:\
            w = max((len(str(c.value)) for c in col if c.value), default=10)\
            ws.column_dimensions[col[0].column_letter].width = min(w + 2, 45)\
    print(f"  Excel вѓ¦ѓІ {xlsx}")\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# STEP 5 вЂѓґ Batch loop\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def process_file(xml_path: str) -> list:\
    """Parse one XML file and return its records."""\
    img_file, rows = parse_xml(xml_path)\
    records = parse_rows(rows, img_file)\
    print(f"  {Path(xml_path).name:50s}  вѓ¦ѓІ  {len(records):>3} records")\
    return records\
\
\
def run(inputs: list, output_base: str):\
    """\
    inputs: list of file or folder paths.\
    Expands folders to all *.xml files inside them.\
    Processes each file and combines into one output.\
    """\
    xml_files = []\
    for inp in inputs:\
        p = Path(inp)\
        if p.is_dir():\
            xml_files.extend(sorted(p.glob("*.xml")))\
        elif p.suffix.lower() == ".xml" and p.exists():\
            xml_files.append(p)\
        else:\
            print(f"WARNING: skipping '{inp}' (not found or not an XML file)")\
\
    if not xml_files:\
        print("ERROR: no XML files found.")\
        sys.exit(1)\
\
    print(f"\nProcessing {len(xml_files)} file(s):\n")\
    all_records = []\
    for xf in xml_files:\
        all_records.extend(process_file(str(xf)))\
\
    if not all_records:\
        print("WARNING: no records extracted from any file.")\
        sys.exit(0)\
\
    df = pd.DataFrame(all_records, columns=[\
        "source_file", "village", "household_rank", "head_name", "caste",\
        "person_name", "hierarchy", "relationship", "named_as", "age", "absent"\
    ])\
\
    print(f"\nTotal: {len(df)} person records across {len(xml_files)} file(s)\n")\
    print(df.to_string(index=False))\
    print()\
    save_outputs(df, output_base)\
    print("\nDone.")\
\
\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
# CLI\
# вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°вѓµѓ°\
\
def main():\
    ap = argparse.ArgumentParser(\
        description=(\
            "Parse VOC Head Thombo PAGE XML transcripts вѓ¦ѓІ CSV / Excel.\n"\
            "Pass one or more XML files, or a folder containing XML files.\n\n"\
            "Examples:\n"\
            "  python3 thombo_parser.py page1.xml\n"\
            "  python3 thombo_parser.py page1.xml page2.xml page3.xml\n"\
            "  python3 thombo_parser.py my_transcripts/\n"\
        ),\
        formatter_class=argparse.RawDescriptionHelpFormatter\
    )\
    ap.add_argument("inputs", nargs="+",\
                    help="XML file(s) or folder(s) containing XML files")\
    ap.add_argument("--output", "-o", default="thombo_output",\
                    help="Output base name (no extension). Default: thombo_output")\
    args = ap.parse_args()\
    run(args.inputs, args.output)\
\
\
if __name__ == "__main__":\
    main()\
